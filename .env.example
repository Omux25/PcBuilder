# PC Builder — Root Environment Variables
# Individual apps may have their own .env files, but these are the common ones.

# Backend (Bun/Hono)
PORT=3000
NODE_ENV=development
SERVE_STATIC=false

# Database (PostgreSQL)
PGHOST=localhost
PGPORT=5433
PGDATABASE=pc_builder
PGUSER=pc_builder_user
PGPASSWORD=pc_builder_pass

# Auth
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=15m

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
