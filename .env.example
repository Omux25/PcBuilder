# PC Builder Maroc — Root Environment Variables
# These are used by Docker Compose and as a template for local development.

# ── Database (Postgres) ───────────────────────────────────────────────────────
DB_NAME=pc_builder
DB_USER=pc_builder_user
DB_PASSWORD=pc_builder_pass_2024
DB_PORT_HOST=5432

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=3000
# Generate with: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production-must-be-32-chars-minimum

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
SERVE_STATIC=false
