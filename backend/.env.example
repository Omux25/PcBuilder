# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pc_builder
DB_USER=pc_builder_user
DB_PASSWORD=changeme

# ─── Connection pool tuning (optional — defaults shown) ───────────────────────
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=600000
DB_CONNECTION_TIMEOUT_MS=30000

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRES_IN=8h
