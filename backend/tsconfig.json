{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "scraper/**/*"],
  "exclude": ["node_modules", "src/**/__tests__/**", "src/__tests__/**"]
}
