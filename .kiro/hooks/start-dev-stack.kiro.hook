{
  "enabled": true,
  "name": "Start Dev Stack",
  "description": "Starts backend (WSL2/Bun), frontend (Vite :5173), and admin panel (Vite :5174) in separate terminal windows",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "powershell -ExecutionPolicy Bypass -File dev.ps1"
  }
}