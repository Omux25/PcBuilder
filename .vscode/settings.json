{
  // Use the workspace TypeScript version instead of VS Code's bundled one
  "typescript.tsdk": "apps/frontend/node_modules/typescript/lib",
  // Suppress red squiggles on test files — bun:test is only available in WSL2/Bun,
  // not in VS Code's Windows TypeScript server. Tests run fine via WSL2.
  "typescript.validate.enable": true,
  "files.exclude": {
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },
  // Trim trailing whitespace and ensure final newline on save
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  // Format on save for TypeScript/TSX files
  "editor.formatOnSave": true,
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "typescript.autoClosingTags": false
}
