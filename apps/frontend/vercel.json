{
  "framework": "vite",
  "rewrites": [
    {
      "source": "/component/(.*)",
      "destination": "/api/seo?path=/component/$1"
    },
    {
      "source": "/presets",
      "destination": "/api/seo?path=/presets"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://pcbuilder-m2nf.onrender.com/api/$1"
    },
    {
      "source": "/api",
      "destination": "https://pcbuilder-m2nf.onrender.com/api"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/admin/index.html"
    },
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
