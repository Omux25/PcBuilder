# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# In Docker: PGHOST=postgres (service name). Locally: PGHOST=127.0.0.1
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=pc_builder
PGUSER=pc_builder_user
PGPASSWORD=
# Set your secure password above

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -hex 32
# The server will refuse to start if this is unset or too short.
# Access tokens expire after 15 minutes (hardcoded, not configurable).
JWT_SECRET=change_me_in_production_min_32_chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * to allow all (dev only).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Static file serving ───────────────────────────────────────────────────────
# Set to "true" in production to serve frontend/dist from the backend process.
# Leave unset or "false" when using Nginx as a reverse proxy.
NODE_ENV=development
SERVE_STATIC=false
