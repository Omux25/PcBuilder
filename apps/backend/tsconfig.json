{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "downlevelIteration": true,
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../../shared/*"],
      "@backend-types/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*",
    "scraper/**/*",
    "scripts/**/*",
    "seed/**/*",
    "../../shared/**/*"
  ],
  "exclude": ["node_modules", "src/**/__tests__/**", "src/__tests__/**"]
}
