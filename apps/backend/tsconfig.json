{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@shared/*": ["../../shared/*"]
    }
  },
  "include": ["src/**/*", "scraper/**/*", "scripts/**/*", "../../shared/**/*"],
  "exclude": ["node_modules", "src/**/__tests__/**", "src/__tests__/**"]
}
