{
  "name": "pc-builder-backend",
  "version": "1.0.0",
  "description": "PC Builder Platform — Bun/Hono backend (run inside WSL2)",
  "module": "src/server.ts",
  "type": "module",
  "scripts": {
    "start": "bun src/server.ts",
    "build": "echo 'No build required for Bun'",
    "dev": "bun --hot src/server.ts",
    "test": "bun test",
    "migrate": "bun src/core/db/migrate.ts",
    "sync": "bun scripts/sync_catalog.ts",
    "enrich": "bun scripts/enrich_database.ts",
    "scrape:pcgamercasa": "bun scripts/scrape_local.ts",
    "worker": "bun scripts/worker.ts"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@hono/zod-validator": "^0.8.0",
    "bcrypt": "6.0.0",
    "cheerio": "1.0.0",
    "fuse.js": "^7.4.2",
    "hono": "4.12.19",
    "jsonwebtoken": "9.0.2",
    "p-queue": "9.2.0",
    "papaparse": "5.5.3",
    "undici": "8.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/bun": "1.3.13",
    "@types/jsonwebtoken": "9.0.10",
    "@types/papaparse": "5.5.2",
    "fast-check": "4.7.0"
  }
