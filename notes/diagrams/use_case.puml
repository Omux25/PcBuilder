@startuml use_case
!theme plain
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecaseBorderColor #555
skinparam usecaseBackgroundColor #FAFAFA

title PC Builder Maroc — Use Cases

left to right direction

actor "User" as U
actor "Admin" as A
actor "Scheduler" as S <<system>>

rectangle "PC Builder Platform" {

  package "Build & Compare" {
    usecase "Select components\nfor a build" as UC1
    usecase "Check compatibility" as UC2
    usecase "Compare prices\nacross retailers" as UC3
    usecase "View price history" as UC4
    usecase "Go to retailer\nwebsite" as UC5
  }

  package "Browse" {
    usecase "Browse component\ncatalog" as UC6
    usecase "Search components" as UC7
    usecase "View preset builds" as UC8
    usecase "View market trends\n(price drops / hikes)" as UC9
  }

  package "Admin — Catalog" {
    usecase "Login" as UC10
    usecase "Create / Edit /\nDelete components" as UC11
    usecase "Bulk import\ncomponents (CSV/JSON)" as UC12
    usecase "Manage preset builds" as UC13
  }

  package "Admin — Scraping" {
    usecase "Trigger scrape\n(one retailer)" as UC14
    usecase "Trigger scrape\n(all retailers)" as UC15
    usecase "Review unmatched\nlistings" as UC16
    usecase "Link listing to\ncatalog component" as UC17
    usecase "View scraper logs" as UC18
  }

  package "Automated" {
    usecase "Scrape retailer\nwebsites" as UC19
    usecase "Match products\nto catalog (DNA)" as UC20
    usecase "Update prices &\nprice history" as UC21
  }
}

U --> UC1
UC1 ..> UC2 : <<include>>
U --> UC3
U --> UC4
U --> UC5
U --> UC6
U --> UC7
U --> UC8
U --> UC9

A --> UC10
A --> UC11
A --> UC12
A --> UC13
A --> UC14
A --> UC15
A --> UC16
UC16 ..> UC17 : <<extend>>
A --> UC18

S --> UC19
UC19 ..> UC20 : <<include>>
UC20 ..> UC21 : <<include>>

@enduml
