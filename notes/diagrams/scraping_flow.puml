@startuml Scraping System Flow
!theme plain
skinparam sequenceMessageAlign center

title Scraping System - 24h Cycle Flow

participant "Bun.cron()\n'0 0 * * *'" as cron
participant "Scheduler" as scheduler
participant "Site1Scraper\n(cheerio+undici)" as s1
participant "Site2Scraper\n(cheerio+undici)" as s2
participant "Aggregator\n(Bun.sql)" as agg
database "PostgreSQL" as db

cron -> scheduler : trigger (every 24h)
scheduler -> db : INSERT scraper_log\n{ level: 'INFO', message: 'Session started' }

scheduler -> s1 : scrape()
alt Success
  s1 -> s1 : undici.fetch(site1_url)
  s1 -> s1 : cheerio.load(html)
  alt Parse success
    s1 -> s1 : extract price, stock, product_url\nper component_id
    s1 --> scheduler : ScrapedPrice[]
  else Parse fails (CSS classes changed)
    s1 -> db : INSERT scraper_log\n{ level: 'ERROR', site: 'site1',\n  message: 'Parse failed — structure changed' }
    s1 -> db : INSERT scraper_log\n{ level: 'WARNING',\n  message: 'Alert: manual review needed' }
    note right : Log error & alert admin\nContinue to next scraper
  end
else Error (timeout / HTTP 429)
  s1 --> scheduler : throws Error
  scheduler -> db : INSERT scraper_log\n{ level: 'ERROR', site: 'site1', message: err }
  note right : Continue to next scraper\nwithout interruption
end

scheduler -> s2 : scrape()
alt Success
  s2 -> s2 : undici.fetch(site2_url)
  s2 -> s2 : cheerio.load(html)
  alt Parse success
    s2 -> s2 : extract price, stock, product_url\nper component_id
    s2 --> scheduler : ScrapedPrice[]
  else Parse fails (CSS classes changed)
    s2 -> db : INSERT scraper_log\n{ level: 'ERROR', site: 'site2',\n  message: 'Parse failed — structure changed' }
    s2 -> db : INSERT scraper_log\n{ level: 'WARNING',\n  message: 'Alert: manual review needed' }
  end
else Error (timeout / HTTP 429)
  s2 --> scheduler : throws Error
  scheduler -> db : INSERT scraper_log\n{ level: 'ERROR', site: 'site2', message: err }
end

scheduler -> agg : aggregate(allResults)

loop For each ScrapedPrice
  agg -> db : INSERT INTO prices\nON CONFLICT (component_id, retailer_id)\nDO UPDATE SET price, in_stock,\nproduct_url, last_updated
end

agg -> db : INSERT scraper_log\n{ level: 'INFO',\n  message: 'Session complete:\n  X updated, Y errors' }

@enduml
