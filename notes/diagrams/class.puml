@startuml class
!theme plain
skinparam classBackgroundColor #FAFAFA
skinparam classBorderColor #555
skinparam arrowColor #333
hide empty members

title PC Builder Maroc — Domain Model

' ── Core domain ──────────────────────────────────────────────────────────────

abstract class Component {
  +id: int
  +name: string
  +brand: string
  +category: ComponentCategory
  +slug: string
  +specs: JSONB
  +is_active: bool
  +benchmark_score: int
}

enum ComponentCategory {
  cpu
  motherboard
  gpu
  ram
  storage
  psu
  case
  cooling
}

class CPU {
  +socket: string
  +tdp: int
}

class Motherboard {
  +socket: string
  +supported_ram_types: string[]
  +max_ram_frequency: int
  +form_factor: string
  +tdp: int
}

class GPU {
  +length_mm: int
  +tdp: int
}

class RAM {
  +ram_type: string
  +frequency_mhz: int
  +tdp: int
}

class Storage {
  +tdp: int
}

class PSU {
  +wattage: int
}

class Case {
  +max_gpu_length_mm: int
  +max_cooler_height_mm: int
  +supported_motherboards: string[]
}

class Cooling {
  +height_mm: int
  +tdp: int
}

Component <|-- CPU
Component <|-- Motherboard
Component <|-- GPU
Component <|-- RAM
Component <|-- Storage
Component <|-- PSU
Component <|-- Case
Component <|-- Cooling
Component --> ComponentCategory

' ── Pricing ──────────────────────────────────────────────────────────────────

class Retailer {
  +id: int
  +name: string
  +base_url: string
  +is_active: bool
  +scraping_interval_hours: int
}

class Price {
  +price: decimal
  +in_stock: bool
  +product_url: string
  +variant_label: string
  +last_updated: timestamp
}

class PriceHistory {
  +price: decimal
  +in_stock: bool
  +recorded_at: timestamp
}

Component "1" *-- "0..*" Price
Retailer "1" *-- "0..*" Price
Component "1" *-- "0..*" PriceHistory
Retailer "1" *-- "0..*" PriceHistory

' ── Scraping ─────────────────────────────────────────────────────────────────

class ScraperMapping {
  +product_url: string
  +product_identifier: string
}

class UnmatchedListing {
  +scraped_name: string
  +scraped_price: decimal
  +product_url: string
  +status: string
}

Component "1" *-- "0..*" ScraperMapping
Retailer "1" *-- "0..*" ScraperMapping
Retailer "1" *-- "0..*" UnmatchedListing

' ── Services ─────────────────────────────────────────────────────────────────

class CompatibilityEngine {
  +validateCompatibility(build): CompatibilityResult
}

class DNAMatcher {
  +findBestMatch(name, catalog): Component
  +extractDna(name, category): string[]
}

class Aggregator {
  +aggregate(prices): AggregateResult
}

CompatibilityEngine ..> Component : uses
DNAMatcher ..> Component : matches to
Aggregator ..> Price : upserts
Aggregator ..> UnmatchedListing : creates

@enduml
