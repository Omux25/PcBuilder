@startuml API Routes
!theme plain
skinparam linetype ortho

title PC Builder Platform - REST API Routes

package "Public Routes (no auth)" as public {
  [GET /api/components\n?category=&socket=&ram_type=] as r1
  [GET /api/components/:id] as r2
  [GET /api/components/:id/prices] as r3
  [POST /api/compatibility/validate] as r4
  [POST /api/auth/login] as r5
}

package "Admin Routes (JWT required) 🔒" as protected {
  [POST /api/admin/components] as r6
  [PUT /api/admin/components/:id] as r7
  [DELETE /api/admin/components/:id] as r8
  [GET /api/admin/logs\n?date=&site=&level=] as r9
  [POST /api/admin/scraper/run 🔒] as r10
}

package "Services" as services {
  [Component Service\n(Bun.sql)] as cs
  [Compatibility Engine] as ce
  [Auth Service\n(bcrypt + JWT)] as as
}

database "PostgreSQL" as db {
  [components] as ct
  [prices] as pt
  [scraper_logs] as lt
  [admins] as at
}

' Public route connections
r1 --> cs : getComponents(filters)
r2 --> cs : getComponentById(id)
r3 --> cs : getPricesByComponentId(id)
r4 --> ce : validateCompatibility(build)
r5 --> as : login(username, password)

' Admin route connections
r6 --> cs : createComponent(data)
r7 --> cs : updateComponent(id, data)
r8 --> cs : deleteComponent(id)
r9 --> lt : queryLogs(filters)
r10 --> scheduler : triggerManualRun()

' Service to DB
cs --> ct
cs --> pt
as --> at

note top of protected
  All admin routes require:
  Authorization: Bearer <JWT>
  Returns HTTP 401 if absent,
  malformed, or expired
end note

note bottom of r3
  Response sorted by
  ascending price.
  Includes last_updated
  per offer.
end note

note bottom of r4
  Returns:
  { compatible, total_tdp,
    recommended_psu_wattage,
    errors[], warnings[] }
  Always HTTP 200
end note

@enduml
