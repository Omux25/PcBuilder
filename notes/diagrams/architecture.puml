@startuml PC Builder Architecture
!theme plain
skinparam componentStyle rectangle
skinparam linetype ortho

title PC Builder Platform - System Architecture

package "Frontend (React + Vite)" as frontend {
  [Configurator UI] as ui
  [Price Comparison View] as priceview
  [Build Summary Panel] as summary
}

package "Backend (Bun + Hono - WSL2)" as backend {
  [REST API\n(Hono)] as api
  [Compatibility Engine] as compat
  [JWT Middleware] as jwt
  [Admin Routes] as admin
  [Component Service] as compservice
  [Zod Validation] as validation
}

package "Scraping System (Bun.cron)" as scraper {
  [Scheduler\n(Bun.cron)] as scheduler
  [Site 1 Scraper\n(cheerio+undici)] as scraper1
  [Site 2 Scraper\n(cheerio+undici)] as scraper2
  [Aggregator\n(Bun.sql)] as aggregator
  [Logger] as logger
}

database "PostgreSQL" as db {
  [components] as comp_table
  [retailers] as ret_table
  [prices] as price_table
  [scraper_logs] as log_table
  [admins] as admin_table
}

' Frontend connections
ui -down-> api : HTTP/REST (JSON)
priceview -down-> api : HTTP/REST (JSON)
summary -down-> api : HTTP/REST (JSON)

' Backend internal
api --> compat : validate build
api --> jwt : authenticate
api --> validation : validate input
api --> compservice : query data
jwt --> admin : protect routes
compservice --> db : SQL (Bun.sql / TCP)

' Scraper connections
scheduler --> scraper1 : trigger
scheduler --> scraper2 : trigger
scraper1 --> aggregator : scraped data
scraper2 --> aggregator : scraped data
aggregator --> price_table : SQL UPSERT
aggregator --> log_table : SQL INSERT
logger --> log_table : SQL INSERT

' Database relationships
compservice --> comp_table
compservice --> price_table
compservice --> ret_table
admin --> admin_table
admin --> log_table

note right of backend
  Runtime: Bun 1.3+
  Framework: Hono
  DB: Bun.sql (built-in)
  All TypeScript
end note

note right of scraper
  Runs every 24h
  cheerio for HTML parsing
  undici for HTTP requests
  Bun.cron() scheduler
end note

@enduml
