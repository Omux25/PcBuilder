@startuml Compatibility Engine Flow
!theme plain
skinparam sequenceMessageAlign center

title Compatibility Engine - Validation Flow

actor User
participant "React UI" as ui
participant "Hono API\nPOST /api/compatibility/validate" as api
participant "Zod Middleware" as zod
participant "Compatibility\nEngine" as engine
database "PostgreSQL\n(Bun.sql)" as db

User -> ui : Selects a component
ui -> api : POST /api/compatibility/validate\n{ cpu, motherboard, gpu, ram,\n  storage, psu, case }

api -> zod : Validate request body
alt Invalid input
  zod --> api : ZodError
  api --> ui : HTTP 400\n{ error: { code: "VALIDATION_ERROR", fields: [...] } }
  ui --> User : Show validation error
end

api -> engine : validateCompatibility(build)

group Socket Check (Property 1)
  engine -> engine : cpu.socket === motherboard.socket?
  alt Mismatch
    engine -> engine : push error: socket_mismatch
  end
end

group RAM Type Check (Property 2)
  engine -> engine : motherboard.supported_ram_types.includes(ram.ram_type)?
  alt Not supported
    engine -> engine : push error: ram_type_mismatch
  end
end

group RAM Frequency Check (Property 3)
  engine -> engine : ram.frequency_mhz > motherboard.max_ram_frequency?
  alt Exceeded
    engine -> engine : push warning: ram_frequency_exceeded
  end
end

group GPU Clearance Check (Property 6)
  engine -> engine : gpu.length_mm > case.max_gpu_length_mm?
  alt Too long
    engine -> engine : push error: gpu_too_long
  end
end

group Physical Clearance Check
  engine -> engine : motherboard form factor\ncompatible with case?
  alt Incompatible form factor
    engine -> engine : push error: form_factor_mismatch
  end
end

group TDP Calculation (Property 4)
  engine -> engine : total_tdp = sum(all component TDPs)
  engine -> engine : recommended_psu = ceil(total_tdp * 1.2)
end

group PSU Check (Property 5)
  engine -> engine : psu.wattage < recommended_psu?
  alt Underpowered
    engine -> engine : push warning: psu_underpowered
  end
end

engine --> api : CompatibilityResult\n{ compatible, total_tdp,\n  recommended_psu_wattage,\n  errors[], warnings[] }

api --> ui : HTTP 200\nCompatibilityResult

ui -> ui : Update Build Summary\nHighlight incompatible components
ui --> User : Show alerts / warnings

@enduml
