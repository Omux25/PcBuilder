@startuml sequence_scraping
!theme plain
skinparam sequenceArrowColor #333
skinparam sequenceParticipantBackgroundColor #FAFAFA
skinparam sequenceParticipantBorderColor #555
skinparam sequenceLifeLineBorderColor #AAA
autonumber

title Sequence 2 — Automated Price Scraping

participant "Bun.cron()\nScheduler" as CRON
participant "ScrapingSession" as SS
participant "Scrapers\n(UltraPC / NextLevel\n/ SetupGame)" as SC
participant "Aggregator" as AGG
participant "DNAMatcher\n+ CatalogBuilder" as DNA
database "PostgreSQL" as DB

CRON -> SS : runScrapingSession()\n[triggered every N hours]

SS -> SC : scrapeAllCategories()\n[up to 2 scrapers in parallel]
SC -> SC : Fetch HTML pages\nvia undici + cheerio\n(retry ×3 on failure)
SC --> SS : ScrapedPrice[]\n{ retailer_id, name, price,\nin_stock, product_url }

SS -> AGG : aggregate(allPrices)

loop for each ScrapedPrice
  AGG -> DB : SELECT scraper_mappings\nWHERE product_url = ?
  alt mapping found
    AGG -> DB : UPSERT prices\n(component_id, retailer_id, product_url)
    AGG -> DB : INSERT price_history\n(only if price changed)
  else no mapping
    AGG -> DB : INSERT unmatched_listings\n(if not already there)
  end
end

AGG --> SS : { updated, unmatched, errors }

SS -> DNA : autoMap()\n[DNA matcher on pending listings]
DNA -> DB : SELECT unmatched_listings\nWHERE status = 'pending'
DNA -> DB : SELECT components (catalog)
DNA -> DNA : extractDna(name, category)\nscoreDnaMatch(tokens, catalog)\nthreshold: 1.0 (0.8 for case/cooling)
DNA -> DB : INSERT scraper_mappings\nfor confident matches
DNA --> SS : { mapped }

SS -> DNA : buildFromUnmatched()\n[auto-create catalog entries]
DNA -> DB : INSERT components\nfrom unmatched product names\n(CPU/GPU/RAM/Storage/MB only)
DNA --> SS : { created }

opt new catalog entries were created
  SS -> DNA : autoMap() — second pass
  DNA --> SS : { mapped }
end

SS -> DB : INSERT scraper_logs\n"Session complete: N updated,\nM unmatched, K auto-mapped"

@enduml
