# ==========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to '.env' on your production server
# and fill in the actual values.

# -----------------
# Environment
# -----------------
NODE_ENV=production
# The domain where your backend is accessible (e.g., https://api.yourdomain.com or https://yourdomain.com)
ALLOWED_ORIGINS=https://yourdomain.com

# -----------------
# Database (PostgreSQL)
# -----------------
# Provide a strong, random password for your database!
DB_USER=pc_builder_user
DB_PASSWORD=your_super_secret_production_password_here
DB_NAME=pc_builder
DB_HOST=postgres
DB_PORT=5432

# -----------------
# Security / Auth
# -----------------
# Generate a strong, random string for JWT_SECRET (e.g., using `openssl rand -hex 32`)
JWT_SECRET=your_super_secret_jwt_string_here
